<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="AiStoryGenerator.Views.MainPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    BackgroundColor="#060D1F">

    <ScrollView>
        <VerticalStackLayout Padding="22,28,22,40" Spacing="0">

            <VerticalStackLayout HorizontalOptions="Center" Spacing="4" Margin="0,0,0,24">

                <HorizontalStackLayout HorizontalOptions="Center" Spacing="10">
                    <BoxView WidthRequest="50" HeightRequest="1"
                             Color="#5A7A45" VerticalOptions="Center"/>
                    <BoxView WidthRequest="6" HeightRequest="6"
                             Color="#8FA87C" Rotation="45" VerticalOptions="Center"/>
                    <BoxView WidthRequest="50" HeightRequest="1"
                             Color="#5A7A45" VerticalOptions="Center"/>
                </HorizontalStackLayout>

                <Label Text="CREATE YOUR HERO"
                       FontSize="22"
                       FontAttributes="Bold"
                       TextColor="#D4C5A9"
                       CharacterSpacing="4"
                       HorizontalOptions="Center"/>

                <Label Text="Craft your legend in the ancient tongue"
                       FontSize="14"
                       TextColor="#7A8E6E"
                       FontAttributes="Italic"
                       CharacterSpacing="1"
                       HorizontalOptions="Center"/>

                <Label Text="ᚠ  ᚱ  ᛟ  ᛗ  ᚹ  ᛏ  ᚾ"
                       FontSize="16"
                       TextColor="#3A5530"
                       HorizontalOptions="Center"
                       CharacterSpacing="4"
                       Margin="0,10,0,0"/>
            </VerticalStackLayout>

            <Border BackgroundColor="#101C12"
                    StrokeThickness="1"
                    Margin="0,0,0,16">
                <Border.Stroke>
                    <SolidColorBrush Color="#2E5028"/>
                </Border.Stroke>
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="4"/>
                </Border.StrokeShape>

                <VerticalStackLayout Padding="20" Spacing="14">

                    <HorizontalStackLayout Spacing="8">
                        <Label Text="HERO CREATION"
                               FontSize="11"
                               CharacterSpacing="2"
                               TextColor="#8FA87C"
                               VerticalOptions="Center"/>
                        <BoxView HorizontalOptions="FillAndExpand" HeightRequest="1"
                                 Color="#2E5028" VerticalOptions="Center"/>
                    </HorizontalStackLayout>

                    <VerticalStackLayout Spacing="4">
                        <Label Text="NAME" FontSize="10" CharacterSpacing="2"
                               TextColor="#5A7A45"/>
                        <Border BackgroundColor="#080F08" StrokeThickness="1">
                            <Border.Stroke>
                                <SolidColorBrush Color="#3A5A2A"/>
                            </Border.Stroke>
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="2"/>
                            </Border.StrokeShape>
                            <Entry x:Name="NameEntry"
                                   Placeholder="Speak your hero's true name..."
                                   PlaceholderColor="#4A5A3A"
                                   TextColor="#C8BC9E"
                                   BackgroundColor="Transparent"
                                   FontSize="15"
                                   Margin="8,4"/>
                        </Border>
                    </VerticalStackLayout>

                    <Grid ColumnDefinitions="*,12,*" RowDefinitions="Auto,Auto">

                        <Label Grid.Column="0" Text="RACE"
                               FontSize="10" CharacterSpacing="2" TextColor="#5A7A45"/>
                        <Label Grid.Column="2" Text="CLASS"
                               FontSize="10" CharacterSpacing="2" TextColor="#5A7A45"/>

                        <Border Grid.Row="1" Grid.Column="0"
                                BackgroundColor="#080F08" StrokeThickness="1">
                            <Border.Stroke>
                                <SolidColorBrush Color="#3A5A2A"/>
                            </Border.Stroke>
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="2"/>
                            </Border.StrokeShape>
                            <Picker x:Name="RacePicker" Title="— Choose —"
                                    TitleColor="#4A5A3A"
                                    TextColor="#C8BC9E"
                                    BackgroundColor="Transparent">
                                <Picker.Items>
                                    <x:String>Elf</x:String>
                                    <x:String>Dark Elf</x:String>
                                    <x:String>Human</x:String>
                                    <x:String>Dwarf</x:String>
                                    <x:String>Orc</x:String>
                                    <x:String>Half-Elf</x:String>
                                </Picker.Items>
                            </Picker>
                        </Border>

                        <Border Grid.Row="1" Grid.Column="2"
                                BackgroundColor="#080F08" StrokeThickness="1">
                            <Border.Stroke>
                                <SolidColorBrush Color="#3A5A2A"/>
                            </Border.Stroke>
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="2"/>
                            </Border.StrokeShape>
                            <Picker x:Name="ClassPicker" Title="— Choose —"
                                    TitleColor="#4A5A3A"
                                    TextColor="#C8BC9E"
                                    BackgroundColor="Transparent">
                                <Picker.Items>
                                    <x:String>Mage</x:String>
                                    <x:String>Ranger</x:String>
                                    <x:String>Paladin</x:String>
                                    <x:String>Assassin</x:String>
                                    <x:String>Necromancer</x:String>
                                    <x:String>Bard</x:String>
                                </Picker.Items>
                            </Picker>
                        </Border>
                    </Grid>

                    <VerticalStackLayout Spacing="4">
                        <Label Text="ALIGNMENT"
           FontSize="10"
           CharacterSpacing="2"
           TextColor="#5A7A45"/>

                        <Border BackgroundColor="#080F08" StrokeThickness="1">
                            <Border.Stroke>
                                <SolidColorBrush Color="#3A5A2A"/>
                            </Border.Stroke>
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="2"/>
                            </Border.StrokeShape>

                            <Picker x:Name="AlignmentPicker"
                Title="— Choose alignment —"
                TitleColor="#4A5A3A"
                TextColor="#C8BC9E"
                BackgroundColor="Transparent">
                                <Picker.Items>
                                    <x:String>Lawful Good</x:String>
                                    <x:String>Neutral Good</x:String>
                                    <x:String>Chaotic Good</x:String>
                                    <x:String>Lawful Neutral</x:String>
                                    <x:String>True Neutral</x:String>
                                    <x:String>Chaotic Neutral</x:String>
                                    <x:String>Lawful Evil</x:String>
                                    <x:String>Neutral Evil</x:String>
                                    <x:String>Chaotic Evil</x:String>
                                </Picker.Items>
                            </Picker>
                        </Border>
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="4">
                        <Label Text="REALM" FontSize="10" CharacterSpacing="2"
                               TextColor="#5A7A45"/>
                        <Border BackgroundColor="#080F08" StrokeThickness="1">
                            <Border.Stroke>
                                <SolidColorBrush Color="#3A5A2A"/>
                            </Border.Stroke>
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="2"/>
                            </Border.StrokeShape>
                            <Picker x:Name="WorldPicker" Title="— Choose a world —"
                                    TitleColor="#4A5A3A"
                                    TextColor="#C8BC9E"
                                    BackgroundColor="Transparent">
                                <Picker.Items>
                                    <x:String>Ancient Kingdom</x:String>
                                    <x:String>Floating Islands</x:String>
                                    <x:String>Magical Forest</x:String>
                                    <x:String>Shadow Realm</x:String>
                                    <x:String>Crystal Desert</x:String>
                                </Picker.Items>
                            </Picker>
                        </Border>
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="4">
                        <Label Text="LORE" FontSize="10" CharacterSpacing="2"
                               TextColor="#5A7A45"/>
                        <Border BackgroundColor="#080F08" StrokeThickness="1">
                            <Border.Stroke>
                                <SolidColorBrush Color="#3A5A2A"/>
                            </Border.Stroke>
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="2"/>
                            </Border.StrokeShape>
                            <Editor x:Name="CustomPrompt"
                                    Placeholder="Describe your hero or the tale you seek..."
                                    PlaceholderColor="#4A5A3A"
                                    HeightRequest="88"
                                    TextColor="#C8BC9E"
                                    BackgroundColor="Transparent"
                                    FontSize="15"
                                    Margin="8,4"/>
                        </Border>
                    </VerticalStackLayout>

                </VerticalStackLayout>
            </Border>

            <Border BackgroundColor="#101C12" StrokeThickness="1" Margin="0,0,0,16">
                <Border.Stroke>
                    <SolidColorBrush Color="#2E5028"/>
                </Border.Stroke>
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="4"/>
                </Border.StrokeShape>

                <VerticalStackLayout Padding="20" Spacing="14">

                    <HorizontalStackLayout Spacing="8">
                        <Label Text="HERO STATS" FontSize="11" CharacterSpacing="2"
                   TextColor="#8FA87C" VerticalOptions="Center"/>
                        <BoxView HorizontalOptions="FillAndExpand" HeightRequest="1"
                     Color="#2E5028" VerticalOptions="Center"/>
                    </HorizontalStackLayout>

                    <HorizontalStackLayout Spacing="6">
                        <Button Text="d4"  CommandParameter="4"  Clicked="OnDiceClicked" Style="{StaticResource DiceButton}"/>
                        <Button Text="d6"  CommandParameter="6"  Clicked="OnDiceClicked" Style="{StaticResource DiceButton}"/>
                        <Button Text="d8"  CommandParameter="8"  Clicked="OnDiceClicked" Style="{StaticResource DiceButton}"/>
                        <Button Text="d10" CommandParameter="10" Clicked="OnDiceClicked" Style="{StaticResource DiceButton}"/>
                        <Button Text="d12" CommandParameter="12" Clicked="OnDiceClicked" Style="{StaticResource DiceButton}"/>
                        <Button Text="d20" CommandParameter="20" Clicked="OnDiceClicked" Style="{StaticResource DiceButton}"/>
                    </HorizontalStackLayout>

                    <Label x:Name="DiceResultLabel"
               Text="Tap a dice to roll it..."
               FontSize="13" FontAttributes="Italic"
               TextColor="#5A7A45"/>

                    <Border BackgroundColor="#803C280A" StrokeThickness="1">
                        <Border.Stroke>
                            <SolidColorBrush Color="#7A6020"/>
                        </Border.Stroke>
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="3"/>
                        </Border.StrokeShape>
                        <Button x:Name="RollAllBtn"
                    Text="◈  Roll All Stats (4d6 drop lowest)  ◈"
                    FontSize="11" CharacterSpacing="2"
                    BackgroundColor="Transparent"
                    TextColor="#C8A850"
                    HeightRequest="46"
                    Clicked="OnRollAllClicked"/>
                    </Border>

                    <Grid ColumnDefinitions="*,8,*,8,*"
              RowDefinitions="Auto,12,Auto" RowSpacing="0">

                        <Border Grid.Column="0" Grid.Row="0" Style="{StaticResource StatBox}">
                            <VerticalStackLayout Spacing="2" HorizontalOptions="Center">
                                <Label Text="STR" Style="{StaticResource StatLabel}"/>
                                <Label x:Name="StatSTR" Text="—" Style="{StaticResource StatValue}"/>
                                <Label x:Name="ModSTR" Text="—" Style="{StaticResource StatMod}"/>
                            </VerticalStackLayout>
                        </Border>

                        <Border Grid.Column="2" Grid.Row="0" Style="{StaticResource StatBox}">
                            <VerticalStackLayout Spacing="2" HorizontalOptions="Center">
                                <Label Text="DEX" Style="{StaticResource StatLabel}"/>
                                <Label x:Name="StatDEX" Text="—" Style="{StaticResource StatValue}"/>
                                <Label x:Name="ModDEX" Text="—" Style="{StaticResource StatMod}"/>
                            </VerticalStackLayout>
                        </Border>

                        <Border Grid.Column="4" Grid.Row="0" Style="{StaticResource StatBox}">
                            <VerticalStackLayout Spacing="2" HorizontalOptions="Center">
                                <Label Text="CON" Style="{StaticResource StatLabel}"/>
                                <Label x:Name="StatCON" Text="—" Style="{StaticResource StatValue}"/>
                                <Label x:Name="ModCON" Text="—" Style="{StaticResource StatMod}"/>
                            </VerticalStackLayout>
                        </Border>

                        <Border Grid.Column="0" Grid.Row="2" Style="{StaticResource StatBox}">
                            <VerticalStackLayout Spacing="2" HorizontalOptions="Center">
                                <Label Text="INT" Style="{StaticResource StatLabel}"/>
                                <Label x:Name="StatINT" Text="—" Style="{StaticResource StatValue}"/>
                                <Label x:Name="ModINT" Text="—" Style="{StaticResource StatMod}"/>
                            </VerticalStackLayout>
                        </Border>

                        <Border Grid.Column="2" Grid.Row="2" Style="{StaticResource StatBox}">
                            <VerticalStackLayout Spacing="2" HorizontalOptions="Center">
                                <Label Text="WIS" Style="{StaticResource StatLabel}"/>
                                <Label x:Name="StatWIS" Text="—" Style="{StaticResource StatValue}"/>
                                <Label x:Name="ModWIS" Text="—" Style="{StaticResource StatMod}"/>
                            </VerticalStackLayout>
                        </Border>

                        <Border Grid.Column="4" Grid.Row="2" Style="{StaticResource StatBox}">
                            <VerticalStackLayout Spacing="2" HorizontalOptions="Center">
                                <Label Text="CHA" Style="{StaticResource StatLabel}"/>
                                <Label x:Name="StatCHA" Text="—" Style="{StaticResource StatValue}"/>
                                <Label x:Name="ModCHA" Text="—" Style="{StaticResource StatMod}"/>
                            </VerticalStackLayout>
                        </Border>
                    </Grid>

                    <Grid x:Name="DerivedStats" IsVisible="False"
              ColumnDefinitions="*,8,*,8,*">
                        <Border Grid.Column="0" Style="{StaticResource StatBox}">
                            <VerticalStackLayout Spacing="2" HorizontalOptions="Center">
                                <Label Text="HP" Style="{StaticResource StatLabel}"/>
                                <Label x:Name="StatHP" Text="—" Style="{StaticResource StatValue}" TextColor="#9A5A5A"/>
                            </VerticalStackLayout>
                        </Border>
                        <Border Grid.Column="2" Style="{StaticResource StatBox}">
                            <VerticalStackLayout Spacing="2" HorizontalOptions="Center">
                                <Label Text="AC" Style="{StaticResource StatLabel}"/>
                                <Label x:Name="StatAC" Text="—" Style="{StaticResource StatValue}" TextColor="#5A7A9A"/>
                            </VerticalStackLayout>
                        </Border>
                        <Border Grid.Column="4" Style="{StaticResource StatBox}">
                            <VerticalStackLayout Spacing="2" HorizontalOptions="Center">
                                <Label Text="INIT" Style="{StaticResource StatLabel}"/>
                                <Label x:Name="StatInit" Text="—" Style="{StaticResource StatValue}" TextColor="#7A8E6E"/>
                            </VerticalStackLayout>
                        </Border>
                    </Grid>

                </VerticalStackLayout>
            </Border>

            <Border BackgroundColor="#0D1F0E"
                    StrokeThickness="1"
                    Margin="0,0,0,16">  
                <Border.Stroke>
                    <SolidColorBrush Color="#5A7A45"/>
                </Border.Stroke>
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="3"/>
                </Border.StrokeShape>

                <VerticalStackLayout Spacing="10">

                    <Button Text="✦  WEAVE THE STORY  ✦"
                FontSize="13"
                HeightRequest="50"
                BackgroundColor="Transparent"
                TextColor="#A8C490"
                CharacterSpacing="3"
                FontAttributes="Bold"
                Clicked="OnGenerateClicked"/>

                    <Button Text="✦ DESCRIBE HERO ✦"
                FontSize="13"
                HeightRequest="45"
                BackgroundColor="Transparent"
                TextColor="#8FA87C"
                CharacterSpacing="2"
                Clicked="OnDescribeHeroClicked"/>

                </VerticalStackLayout>
            </Border>

            <Border BackgroundColor="#080F08"
                    StrokeThickness="1"
                    Margin="0,0,0,16">
                <Border.Stroke>
                    <SolidColorBrush Color="#2E5028"/>
                </Border.Stroke>
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="4"/>
                </Border.StrokeShape>

                <VerticalStackLayout Padding="20" Spacing="12">
                    <HorizontalStackLayout Spacing="8">
                        <Label Text="HERO PORTRAIT"
                               FontSize="11" CharacterSpacing="2" TextColor="#8FA87C"
                               VerticalOptions="Center"/>
                        <BoxView HorizontalOptions="FillAndExpand" HeightRequest="1"
                                 Color="#2E5028" VerticalOptions="Center"/>
                    </HorizontalStackLayout>

                    <Border BackgroundColor="#060D06" StrokeThickness="1">
                        <Border.Stroke>
                            <SolidColorBrush Color="#2A4020"/>
                        </Border.Stroke>
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="2"/>
                        </Border.StrokeShape>

                        <Image x:Name="CharacterImage"
                           Aspect="AspectFit"
                           BackgroundColor="#060D06"
                           IsVisible="False"/>      
                    </Border>
                </VerticalStackLayout>
            </Border>

            <Border BackgroundColor="#101C12"
        StrokeThickness="1"
        Margin="0,0,0,16">
                <Border.Stroke>
                    <SolidColorBrush Color="#2E5028"/>
                </Border.Stroke>
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="4"/>
                </Border.StrokeShape>

                <VerticalStackLayout Padding="20" Spacing="12">
                    <HorizontalStackLayout Spacing="8">
                        <Label Text="THE CHRONICLE"
                   FontSize="11" CharacterSpacing="2" TextColor="#8FA87C"
                   VerticalOptions="Center"/>
                        <BoxView HorizontalOptions="FillAndExpand" HeightRequest="1"
                     Color="#2E5028" VerticalOptions="Center"/>
                    </HorizontalStackLayout>

                    <Border BackgroundColor="#080F08" StrokeThickness="1">
                        <Border.Stroke>
                            <SolidColorBrush Color="#2A4020"/>
                        </Border.Stroke>
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="2"/>
                        </Border.StrokeShape>

                        <Editor x:Name="StoryEditor"
                    HeightRequest="220"
                    TextColor="#C0B49A"
                    BackgroundColor="Transparent"
                    FontSize="15"
                    FontAttributes="Italic"
                    Placeholder="Your legend awaits the forge..."
                    PlaceholderColor="#3A5A2A"
                    Margin="8,4"/>
                    </Border>
                </VerticalStackLayout>
            </Border>

            <Border BackgroundColor="#101C12"
        StrokeThickness="1"
        Margin="0,0,0,16">
                <Border.Stroke>
                    <SolidColorBrush Color="#2E5028"/>
                </Border.Stroke>
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="4"/>
                </Border.StrokeShape>

                <VerticalStackLayout Padding="20" Spacing="12">
                    <HorizontalStackLayout Spacing="8">
                        <Label Text="HERO DESCRIPTION"
                   FontSize="11"
                   CharacterSpacing="2"
                   TextColor="#8FA87C"
                   VerticalOptions="Center"/>
                        <BoxView HorizontalOptions="FillAndExpand"
                     HeightRequest="1"
                     Color="#2E5028"
                     VerticalOptions="Center"/>
                    </HorizontalStackLayout>

                    <Border BackgroundColor="#080F08" StrokeThickness="1">
                        <Border.Stroke>
                            <SolidColorBrush Color="#2A4020"/>
                        </Border.Stroke>
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="2"/>
                        </Border.StrokeShape>

                        <Editor x:Name="DescriptionEditor"
                    HeightRequest="120"
                    TextColor="#C0B49A"
                    BackgroundColor="Transparent"
                    FontSize="15"
                    FontAttributes="Italic"
                    Placeholder="Hero description will appear here..."
                    PlaceholderColor="#3A5A2A"
                    Margin="8,4"/>
                    </Border>
                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>